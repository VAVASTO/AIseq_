# Copy to .env — never commit .env (see .gitignore).

# xAI / Grok (same as safety_judge_eval: OpenAI-compatible client)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.20-non-reasoning

# OpenRouter (example — same vars used by Promptfoo configs in this repo):
# LLM_JUDGE_API_KEY=sk-or-v1-...
# LLM_JUDGE_BASE_URL=https://openrouter.ai/api/v1
# LLM_JUDGE_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_NAME=JudgeBench

# Cost / scope (Python compat script ``run_xai_judge_promptfoo_compat.py``):
# MAX_CASES=40          # optional: only first N rows of cases.jsonl
# JUDGE_MAX_OUTPUT_TOKENS=120   # short JSON verdicts; lower = cheaper
# RUN_STACKS=geval,closedqa     # optional: skip stacks (e.g. llm_rubric already done)

# Optional: legacy names still read by run_llamator.py if XAI_* unset
JUDGE_API_BASE=http://localhost:1234/v1
JUDGE_API_KEY=dummy
JUDGE_MODEL=qwen2.5-7b-instruct

MOCK_TARGET_BASE=http://localhost:8000/v1
